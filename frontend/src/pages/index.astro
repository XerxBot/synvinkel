---
import Base from '../layouts/Base.astro';
import SearchPage from '../components/SearchPage';
import { fetchSources, CLIENT_BASE } from '../lib/api';

const sources = await fetchSources().catch(() => []);
---
<Base title="Synvinkel" description="Alla har en synvinkel — vi visar vilken.">

  <!-- Hero -->
  <div class="bg-navy-900 text-white py-14 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <div class="flex justify-center mb-5">
        <div class="w-16 h-16 rounded-full"
             style="background: linear-gradient(135deg, #dc2626 0%, #d1d5db 50%, #1d4ed8 100%)"></div>
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold mb-4 tracking-tight">
        Alla har en synvinkel
      </h1>
      <p class="text-xl text-gray-300 mb-2">Vi visar vilken.</p>
      <p class="text-gray-400 max-w-xl mx-auto text-sm leading-relaxed mt-4">
        Synvinkel analyserar politisk vinkling i svenska medier och organisationers publikationer.
        Ingen skylt på dörren — transparent finansiering, öppen källkod.
      </p>
      <div class="flex justify-center gap-6 mt-8 text-xs text-gray-500">
        <span>39 klassificerade källor</span>
        <span>·</span>
        <span>9 aktiva scrapers</span>
        <span>·</span>
        <span>Öppen källkod</span>
      </div>
    </div>
  </div>

  <!-- Search -->
  <div class="max-w-4xl mx-auto px-4 py-10">
    <SearchPage apiBase={CLIENT_BASE} sources={sources} client:load />
  </div>

</Base>
